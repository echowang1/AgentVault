{
  "name": "@agent-vault/sdk",
  "version": "0.1.0",
  "description": "MPC Wallet SDK for AI Agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "lint": "echo 'lint not configured'",
    "format": "echo 'format not configured'",
    "example:create": "tsx ../examples/basic/01-create-wallet.ts",
    "example:sign-message": "tsx ../examples/basic/02-sign-message.ts",
    "example:sign-tx": "tsx ../examples/basic/03-sign-transaction.ts",
    "example:set-policy": "tsx ../examples/basic/04-set-policy.ts",
    "examples": "npm-run-all example:*",
    "test:e2e": "vitest run --config vitest.e2e.config.ts tests/e2e.test.ts",
    "test:perf": "vitest run --config vitest.e2e.config.ts tests/performance.test.ts"
  },
  "keywords": [
    "mpc",
    "wallet",
    "web3",
    "agent",
    "threshold-signature",
    "tss",
    "vault",
    "agent-vault"
  ],
  "author": "echowang1",
  "license": "MIT",
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "ethers": "^6.16.0"
  }
}
